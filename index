<script>
    (function() {
        window.addEventListener('load', () => {
            setTimeout(() => document.getElementById('preloader').classList.add('hidden'), 500);
        });

        const body = document.body;
        const langBtn = document.getElementById('langSwitchBtn');
        let isFrench = localStorage.getItem('lang') === 'fr';
        
        function applyLang() {
            if (isFrench) {
                body.classList.add('lang-fr');
                body.setAttribute('dir', 'ltr');
                body.setAttribute('lang', 'fr');
            } else {
                body.classList.remove('lang-fr');
                body.setAttribute('dir', 'rtl');
                body.setAttribute('lang', 'ar');
            }
            localStorage.setItem('lang', isFrench ? 'fr' : 'ar');
        }
        applyLang();

        langBtn.addEventListener('click', () => {
            isFrench = !isFrench;
            applyLang();
        });

        const navbar = document.getElementById('navbar');
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const navLinks = document.getElementById('navLinks');
        const allNavLinks = navLinks.querySelectorAll('a');

        window.addEventListener('scroll', () => {
            navbar.classList.toggle('scrolled', window.scrollY > 50);
            document.getElementById('backToTop').classList.toggle('visible', window.scrollY > 500);
        });

        hamburgerBtn.addEventListener('click', () => navLinks.classList.toggle('active'));
        allNavLinks.forEach(link => {
            link.addEventListener('click', () => navLinks.classList.remove('active'));
        });

        window.addEventListener('scroll', () => {
            const sections = document.querySelectorAll('section[id]');
            let current = '';
            sections.forEach(sec => {
                if (window.scrollY >= sec.offsetTop - 120) current = sec.getAttribute('id');
            });
            allNavLinks.forEach(a => a.classList.remove('active'));
            if (current) {
                const activeLink = navLinks.querySelector(`a[href="#${current}"]`);
                if (activeLink) activeLink.classList.add('active');
            }
        });

        document.querySelectorAll('.faq-question').forEach(btn => {
            btn.addEventListener('click', () => {
                const item = btn.parentElement;
                document.querySelectorAll('.faq-item').forEach(i => {
                    if (i !== item) i.classList.remove('active');
                });
                item.classList.toggle('active');
            });
        });

        let countersAnimated = false;
        function animateCounters() {
            if (countersAnimated) return;
            const counters = document.querySelectorAll('.chiffre-number');
            counters.forEach(c => {
                const target = +c.getAttribute('data-target');
                const dur = 1200;
                const step = target / (dur / 16);
                let current = 0;
                function update() {
                    current += step;
                    if (current < target) {
                        c.textContent = Math.ceil(current);
                        requestAnimationFrame(update);
                    } else {
                        c.textContent = target;
                    }
                }
                update();
            });
            countersAnimated = true;
        }

        const chiffresObserver = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) animateCounters();
        }, { threshold: 0.4 });
        const chiffresSection = document.querySelector('.chiffres-grid');
        if (chiffresSection) chiffresObserver.observe(chiffresSection);

        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();
            this.style.display = 'none';
            document.getElementById('formSuccessMsg').style.display = 'block';
            setTimeout(() => {
                this.style.display = 'block';
                document.getElementById('formSuccessMsg').style.display = 'none';
                this.reset();
            }, 4000);
        });

        const modal = document.getElementById('visiteModal');
        document.getElementById('openModalBtn').addEventListener('click', () => {
            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
        });
        document.getElementById('closeModalBtn').addEventListener('click', () => {
            modal.classList.remove('show');
            document.body.style.overflow = '';
        });
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.remove('show');
                document.body.style.overflow = '';
            }
        });
        document.getElementById('visiteForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const msg = isFrench ? '✅ Demande envoyée !' : '✅ تم إرسال طلب الزيارة!';
            alert(msg);
            modal.classList.remove('show');
            document.body.style.overflow = '';
            this.reset();
        });

        document.getElementById('backToTop').addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        console.log('🌱 براعم المستقبل — الموقع جاهز !');
    })();
</script>

